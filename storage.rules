rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function familyDoc(familyId) {
      return firestore.get(/databases/(default)/documents/families/$(familyId));
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && familyDoc(familyId).data.members.hasAny([request.auth.uid]);
    }

    function isImageUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('image/.*');
    }

    match /avatars/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == userId
        && isImageUpload(5 * 1024 * 1024);
    }

    match /families/{familyId}/recipes/{recipeId}/{fileName} {
      allow read: if isFamilyMember(familyId);
      allow write: if isFamilyMember(familyId)
        && isImageUpload(10 * 1024 * 1024);
    }
  }
}
